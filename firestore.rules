rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: staffs
    // Document ID: staffId
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (required) - Full name
    //   - username: string (required) - Username for login
    //   - role: string (required, enum: ["Admin", "Editor", "Viewer"]) - User role
    //   - status: string (required, enum: ["Active", "Inactive"]) - Account status
    //   - pages: list (required) - Pages the user can access
    //   - createdAt: timestamp (optional) - Creation timestamp
    //
    // Collection: registrations
    // Document ID: registrationId
    // Fields:
    //   - username: string (required) - Requested username
    //   - password: string (required) - Requested password
    //   - status: string (required, enum: ["Pending", "Approved", "Rejected"]) - Request status
    //   - type: string (optional) - Type of registration request
    //   - details: string (optional) - Description of the request
    //   - timestamp: timestamp (required) - Request timestamp
    //   - pageAccess: string (optional) - Default page access
    //
    // Collection: inventory
    // Document ID: itemId
    // Fields:
    //   - sectionTitle: string (required)
    //   - subSectionTitle: string (required)
    //   - size: string (required)
    //   - gsm: string (required)
    //   - stock: number (required)
    //   - minQuantity: number (optional)
    //   - remarks: string (optional)
    //   - isLow: bool (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/staffs/$(request.auth.uid)) && get(/databases/$(database)/documents/staffs/$(request.auth.uid)).data.role == 'Admin' ||
         (request.auth.token.email == "shafi3396@gmail.com" && request.auth.token.email_verified == true));
    }

    function isEditor() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/staffs/$(request.auth.uid)) && get(/databases/$(database)/documents/staffs/$(request.auth.uid)).data.role in ['Admin', 'Editor'] ||
         (request.auth.token.email == "shafi3396@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidStaff(data) {
      return hasRequiredFields(['uid', 'name', 'username', 'role', 'status', 'pages']) &&
             hasOnlyAllowedFields(['uid', 'name', 'username', 'role', 'status', 'pages', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.role in ['Admin', 'Editor', 'Viewer'] &&
             data.status in ['Active', 'Inactive'] &&
             data.pages is list && data.pages.size() <= 10;
    }

    function isValidRegistration(data) {
      return hasRequiredFields(['username', 'password', 'status', 'timestamp']) &&
             hasOnlyAllowedFields(['username', 'password', 'status', 'type', 'details', 'timestamp', 'pageAccess']) &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.password is string && data.password.size() > 0 && data.password.size() < 100 &&
             data.status in ['Pending', 'Approved', 'Rejected'] &&
             data.timestamp is timestamp;
    }

    function isValidInventory(data) {
      return hasRequiredFields(['sectionTitle', 'subSectionTitle', 'size', 'gsm', 'stock']) &&
             data.sectionTitle is string && data.subSectionTitle is string &&
             data.size is string && data.gsm is string && data.stock is number;
    }

    function isValidAuditLog(data) {
      return hasRequiredFields(['action', 'user', 'timestamp']) &&
             hasOnlyAllowedFields(['action', 'user', 'timestamp']) &&
             data.action is string && data.action.size() > 0 && data.action.size() < 500 &&
             data.user is string && data.user.size() > 0 && data.user.size() < 100 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /staffs/{staffId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidStaff(request.resource.data) && (isOwner(staffId) || isAdmin());
      allow update: if isAuthenticated() && isValidStaff(request.resource.data) && (isOwner(staffId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow read: if true; // Allow read for everyone to fix admin panel notification
      allow create: if isValidRegistration(request.resource.data); // Anyone can create
      allow update: if isAdmin() && isValidRegistration(request.resource.data);
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if true;
      // TEMPORARY FIX: Allowing create for everyone because local authentication is not compatible with Firebase Auth.
      // This is insecure and should be replaced with proper Firebase Authentication.
      allow create: if true; 
      allow update: if isEditor() && isValidInventory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /stockInLogs/{logId} {
      allow read: if true;
      allow create: if true; // Relaxed for local auth
      allow update: if true; // Relaxed for local auth
      allow delete: if isAdmin();
    }

    match /stockOutLogs/{logId} {
      allow read: if true;
      allow create: if true; // Relaxed for local auth
      allow update: if true; // Relaxed for local auth
      allow delete: if isAdmin();
    }

    match /pendingWorks/{workId} {
      allow read: if true;
      allow create: if true; // Relaxed for local auth
      allow update: if true; // Relaxed for local auth
      allow delete: if isAdmin();
    }

    match /reorderDrafts/{draftId} {
      allow read, write: if true;
    }

    match /quickTrackerHistory/{logId} {
      allow read: if true;
      allow create: if true; // Relaxed for local auth
      allow update: if true; // Relaxed for local auth
      allow delete: if isAdmin();
    }

    match /reorderHistory/{logId} {
      allow read: if true;
      allow create: if true; // Relaxed for local auth
      allow update: if true; // Relaxed for local auth
      allow delete: if isAdmin();
    }

    match /jobCards/{cardId} {
      allow read: if true;
      allow create: if true; // Relaxed for local auth
      allow update: if true; // Relaxed for local auth
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if true;
      // TEMPORARY FIX: Allowing create for everyone because local authentication is not compatible with Firebase Auth.
      allow create: if isValidAuditLog(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
